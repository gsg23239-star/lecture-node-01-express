{
  "name": "lecture-nodejs-01-expess",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
      "dev": "tsx watch src/index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
  }
  "compilerOptions": {
    // 1. 디렉토리 설정
    "rootDir": "./src",
    "outDir": "./dist",
    // 2. 모듈 및 환경 설정
    "module": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    // 3. 소스맵 (디버깅 용도)
    "sourceMap": true,
    // 4. 엄격한 타입 체크
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // 5. 모듈 호환성 및 기타 권장 설정
    "esModuleInterop": true,
    // CommonJS 모듈을 ES6처럼 가져오기 위해 추가
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
    // node_modules 내부의 타입 체크 생략 (빌드 속도 향상)
  }
}

